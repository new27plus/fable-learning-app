{
  "expo": {
    "name": "寓言学堂",
    "slug": "fable-learning-app",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "fable-learning-app",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fablelearning.app",
      "buildNumber": "1",
      "infoPlist": {
        "CFBundleDisplayName": "寓言学堂",
        "CFBundleShortVersionString": "1.3.0",
        "CFBundleVersion": "1",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF8F0"
      },
      "package": "com.fablelearning.app",
      "versionCode": 1
    },
    "platforms": ["ios", "android", "web"],
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "experiments": {
      "baseUrl": "/fable-learning-app"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-asset"
    ]
  }
}
