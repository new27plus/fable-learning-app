{
  "expo": {
    "name": "寓言学堂",
    "slug": "fable-learning-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "fable-learning-app",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fablelearning.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF8F0"
      },
      "package": "com.fablelearning.app"
    },
    "platforms": ["ios", "android"],
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-asset"
    ]
  }
}
